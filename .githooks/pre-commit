#!/bin/bash
# FarmscapeOS вЂ” Pre-commit hook
# Runs gitleaks for secret detection + checks for forbidden files/directories.
#
# Setup (run once after cloning):
#   git config core.hooksPath .githooks
#
# To install gitleaks:
#   brew install gitleaks          # macOS
#   sudo apt install gitleaks      # Debian/Ubuntu
#   go install github.com/gitleaks/gitleaks/v8@latest  # Go
#
# Bypass for false positives:
#   git commit --no-verify

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'
BLOCKED=0

echo "рџ”Ќ FarmscapeOS pre-commit scan..."

# в”Ђв”Ђ 1. Forbidden files/directories в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

FORBIDDEN_PATHS=(
  'db-snapshots/'
  '\.env$'
  '\.env\.'
  '\.dev\.vars$'
  '\.wrangler/'
  '\.pem$'
  '\.key$'
  '\.p12$'
  '\.pfx$'
  '\.jks$'
  '\.keystore$'
  'id_rsa'
  'id_ed25519'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

for file in $STAGED_FILES; do
  for pattern in "${FORBIDDEN_PATHS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}BLOCKED${NC}: '$file' matches forbidden path pattern '${pattern}'"
      BLOCKED=1
    fi
  done
done

# в”Ђв”Ђ 2. Load user-specific secret patterns (.secret-patterns) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# This file is gitignored. Each contributor creates their own with
# farm-specific terms (property names, addresses, personal info).

if [ -f ".secret-patterns" ]; then
  echo "  Loading custom patterns from .secret-patterns..."
  while IFS= read -r pattern; do
    [[ "$pattern" =~ ^#.*$ || -z "$pattern" ]] && continue
    for file in $STAGED_FILES; do
      if [ -f "$file" ] && ! file "$file" | grep -q "binary"; then
        DIFF=$(git diff --cached -- "$file" 2>/dev/null || true)
        if echo "$DIFF" | grep -qiE "$pattern"; then
          MATCH=$(echo "$DIFF" | grep -iE "$pattern" | head -1 | sed 's/^+//' | xargs)
          echo -e "${RED}BLOCKED${NC}: '$file' matches custom pattern '${pattern}'"
          echo "  в†’ $MATCH"
          BLOCKED=1
        fi
      fi
    done
  done < ".secret-patterns"
fi

# в”Ђв”Ђ 3. Gitleaks (800+ built-in rules + .gitleaks.toml custom rules) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if command -v gitleaks &> /dev/null; then
  echo "  Running gitleaks..."
  if ! gitleaks protect --staged --config .gitleaks.toml --no-banner 2>/dev/null; then
    echo -e "${RED}BLOCKED${NC}: gitleaks detected secrets in staged files."
    echo "  Run 'gitleaks protect --staged --verbose' for details."
    BLOCKED=1
  fi
else
  echo -e "${YELLOW}WARNING${NC}: gitleaks not installed. Skipping automated secret scan."
  echo "  Install: brew install gitleaks (macOS) or see README."
fi

# в”Ђв”Ђ Result в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if [ $BLOCKED -eq 1 ]; then
  echo ""
  echo -e "${RED}Commit blocked.${NC} Potential private data detected in staged files."
  echo "Fix the issues above, or bypass with: git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}вњ… No private data detected. Proceeding with commit.${NC}"
